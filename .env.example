# =============================================================================
# torque-dash-next Production Configuration
# =============================================================================
# Copy this file to .env and configure your settings.
# Then run: docker compose -f docker-compose.prod.yml up -d
#
# IMPORTANT: The app will NOT start without the required variables below.
# Generate secure values with:
#   openssl rand -base64 24  # for POSTGRES_PASSWORD
#   openssl rand -hex 24     # for SESSION_KEYS
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# PostgreSQL/TimescaleDB credentials. Use the same values for all three.
POSTGRES_DB=torquedash
POSTGRES_USER=torquedash
POSTGRES_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD

# -----------------------------------------------------------------------------
# Session Security (REQUIRED)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 24
# For key rotation, use comma-separated values: key1,key2,key3
SESSION_KEYS=CHANGE_ME_TO_A_RANDOM_HEX_STRING

# -----------------------------------------------------------------------------
# Upload Authentication
# -----------------------------------------------------------------------------
# Bearer token required for Torque Pro uploads.
# Generate with: openssl rand -hex 24
# Torque Pro must send: Authorization: Bearer <this-token>
#
# OPTIONAL: If not set here, you can generate a token from the Settings page
# in the web UI after logging in. The UI-generated token takes precedence.
UPLOAD_API_TOKEN=

# -----------------------------------------------------------------------------
# Cookie Settings
# -----------------------------------------------------------------------------
# Set to true behind HTTPS reverse proxy (recommended for production)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Upload rate limit (per IP)
UPLOAD_RATE_LIMIT_MAX=600
UPLOAD_RATE_LIMIT_WINDOW_MS=60000

# Auth rate limit (login/register per IP)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000

# Write rate limit (settings mutations per IP)
WRITE_RATE_LIMIT_MAX=30
WRITE_RATE_LIMIT_WINDOW_MS=60000

# Read rate limit (all other /api routes per IP)
READ_RATE_LIMIT_MAX=600
READ_RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# Registration
# -----------------------------------------------------------------------------
# Set to true to disable public sign-ups
# DISABLE_REGISTRATION=true
